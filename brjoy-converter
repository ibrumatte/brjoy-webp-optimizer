        self._add_files([f.strip("{}") for f in files])

    def _iter_supported_images(self, root_path):
        """Itera imagens suportadas de forma recursiva, ignorando pastas conhecidas."""
        root_path = Path(root_path)
        stack = [(root_path, 0)]
        collected = 0

        while stack and collected < MAX_DROP_SCAN_FILES:
            current, depth = stack.pop()
            if depth > 10:
                continue

            try:
                items = sorted(current.iterdir(), key=lambda p: p.name.lower())
            except (PermissionError, FileNotFoundError, NotADirectoryError):
                continue

            for item in items:
                if collected >= MAX_DROP_SCAN_FILES:
                    break
                if item.is_dir():
                    if item.name not in IGNORED_DIRS:
                        stack.append((item, depth + 1))
                elif item.is_file() and item.suffix.lower() in SUPPORTED_EXTENSIONS:
                    collected += 1
                    yield item

    def _add_files(self, paths):
        """Helper para adicionar arquivos validando extensões e duplicatas"""
        novos = []
        existentes = {arq["path"] for arq in self.arquivos if isinstance(arq, dict) and "path" in arq}

        def add_file(path_obj):
            abs_path = str(path_obj.resolve())
            if abs_path in existentes:
                return
            if self.pasta_origem:
                try:
                    rel_path = path_obj.resolve().relative_to(self.pasta_origem.resolve())
                except ValueError:
                    rel_path = path_obj.name
            else:
                rel_path = path_obj.name
            novos.append(self._new_file_entry(path_obj, rel_path=rel_path))
            existentes.add(abs_path)

        for path_str in paths:
            path = Path(path_str)
            
            if path.is_file() and path.suffix.lower() in SUPPORTED_EXTENSIONS:
                add_file(path)
            elif path.is_dir():
                for img in self._iter_supported_images(path):
                    add_file(img)
        
        if novos:
            self.arquivos.extend(novos)
            self.atualizar_lista()

