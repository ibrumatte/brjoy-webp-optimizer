    def _save_history(self, folder, success, errors, total):
        """Salva conversão no histórico"""
        try:
            timestamp = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
            entry = f"{timestamp} | {success}/{total} OK | {errors} errors | {folder}\n"
            with open(self.history_file, "a") as f:
                f.write(entry)
        except Exception as e:
            print(f"Failed to save history: {e}")

    def show_history(self):
        """Mostra histórico de conversões"""
        if not self.history_file.exists():
            messagebox.showinfo("History", "No conversion history yet")
            return
        
        try:
            with open(self.history_file, "r") as f:
                lines = f.readlines()[-20:]  # Últimas 20 conversões
            
            history_text = "".join(reversed(lines)) if lines else "No history"
            
            # Criar janela de histórico
            win = tk.Toplevel(self.root)
            win.title("Conversion History")
            win.geometry("700x400")
            win.configure(bg=COLORS["bg"])
            
            text = tk.Text(win, font=("Courier", 9), bg=COLORS["card"], fg=COLORS["text"],
                          relief=tk.FLAT, padx=12, pady=12)
            text.pack(fill=tk.BOTH, expand=True, padx=16, pady=16)
            text.insert("1.0", history_text)
            text.config(state=tk.DISABLED)
            
            tk.Button(win, text="Clear History", command=lambda: self._clear_history(win),
                     font=("Arial", 9), bg="#ef4444", fg="#ffffff",
                     padx=16, pady=8, cursor="hand2", relief=tk.FLAT).pack(pady=(0, 16))
        except Exception as e:
            messagebox.showerror("Error", f"Failed to load history: {e}")

    def _clear_history(self, window):
        """Limpa histórico"""
        if messagebox.askyesno("Clear History", "Delete all conversion history?"):
            try:
                self.history_file.unlink(missing_ok=True)
                window.destroy()
                messagebox.showinfo("Success", "History cleared")
            except Exception as e:
                messagebox.showerror("Error", f"Failed to clear history: {e}")

    def verificar_dependencias(self):
        try:
            subprocess.run(["convert", "-version"], capture_output=True, check=True)
        except (subprocess.CalledProcessError, FileNotFoundError):
            resposta = messagebox.askyesno(
                "ImageMagick não encontrado",
                "O ImageMagick é necessário para converter imagens.\n\nDeseja instalar agora?"
            )
            if resposta:
                if shutil.which("x-terminal-emulator"):
                    subprocess.run(["x-terminal-emulator", "-e", "sudo apt install imagemagick"])
                else:
                    messagebox.showinfo(
                        "Instalação manual",
                        "Abra um terminal e execute:\n\nsudo apt install imagemagick"
                    )

    def criar_pasta_sessao(self, pasta_origem=None):
        if not self.pasta_saida.get():
            if pasta_origem is None:
                pasta_origem = Path(self.arquivos[0]["path"]).parent
            timestamp = datetime.now().strftime("%Y-%m-%d_%H-%M-%S")

            try:
                result = subprocess.run([
                    "zenity", "--entry",
                    "--title=Nome da pasta",
                    "--text=Nome para a pasta de saída:",
                    "--entry-text=BrJoy_" + timestamp
                ], capture_output=True, text=True)

                if result.returncode == 0 and result.stdout.strip():
                    nome_pasta = result.stdout.strip()
                else:
                    nome_pasta = "BrJoy_" + timestamp
            except (subprocess.SubprocessError, FileNotFoundError, OSError):
                nome_pasta = "BrJoy_" + timestamp

            pasta_final = pasta_origem / nome_pasta
            pasta_final.mkdir(parents=True, exist_ok=True)
            self.pasta_saida.set(str(pasta_final))
            return pasta_final
        else:
            pasta_final = Path(self.pasta_saida.get())
            pasta_final.mkdir(parents=True, exist_ok=True)
            return pasta_final

    def _get_session_folder(self, arquivos_snapshot, config):
        """Resolve pasta base da sessão para histórico/relatórios."""
        if self.pasta_saida.get():
            pasta = Path(self.pasta_saida.get())
            pasta.mkdir(parents=True, exist_ok=True)
            return pasta

        first_parent = Path(arquivos_snapshot[0]["path"]).parent
        if config["substituir_no_lugar"]:
            return first_parent

        return self.criar_pasta_sessao(pasta_origem=first_parent)

