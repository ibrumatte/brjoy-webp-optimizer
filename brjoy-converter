def requires_idle(func):
    """Decorator para métodos que só funcionam quando não está convertendo"""
    def wrapper(self, *args, **kwargs):
        if not self.convertendo:
            return func(self, *args, **kwargs)
    return wrapper


class ConversorHEIC:
    def __init__(self, root):
        self.root = root
        self.root.title("BrJoy Image Converter")
        self.root.geometry("800x600")
        self.root.configure(bg=COLORS["bg"])
        self.root.resizable(True, True)
        self.root.minsize(700, 500)

        try:
            icon_path = Path.home() / ".local/share/brjoy-image-converter/icon.png"
            if icon_path.exists():
                icon = tk.PhotoImage(file=str(icon_path))
                self.root.iconphoto(True, icon)
        except Exception:
            pass

        # State
        self.formato = tk.StringVar(value="webp")
        self.arquivos = []
        self.pasta_saida = tk.StringVar(value="")
        self.redimensionar = tk.BooleanVar(value=False)
        self.largura_max = tk.StringVar(value="1920")
        self.altura_max = tk.StringVar(value="")
        self.recorte_1x1 = tk.BooleanVar(value=False)
        self.aspect_ratio = tk.StringVar(value="")
        self.convertendo = False
        self.drop_active = False

        self.criar_interface()
        self.setup_keyboard_shortcuts()
        self.atualizar_estado()
        self.verificar_dependencias()

    def setup_keyboard_shortcuts(self):
        self.root.bind("<Control-o>", lambda e: self.selecionar_arquivos())
        self.root.bind("<Control-O>", lambda e: self.selecionar_arquivos())
        self.root.bind("<Delete>", lambda e: self.remover_selecionados())
        self.root.bind("<Control-Return>", lambda e: self.converter())

    @requires_idle
    def remover_selecionados(self):
        indices = sorted([self.tree.index(item) for item in self.tree.selection()], reverse=True)
        for idx in indices:
            del self.arquivos[idx]
        self.atualizar_lista()

    @requires_idle
    def aplicar_preset(self, event=None):
        preset = PRESETS.get(self.preset_var.get())
        if not preset:
            return

        self.recorte_1x1.set(preset["crop"])
        self.redimensionar.set(preset["resize"])
        self.largura_max.set(str(preset["width"]))
        self.altura_max.set(str(preset.get("height", "")))
        self.aspect_ratio.set(preset.get("aspect", ""))
        self.toggle_resize()

    def setup_drag_drop(self, widget):
        if not DND_AVAILABLE:
            return

        widget.drop_target_register(DND_FILES)
        widget.dnd_bind("<<Drop>>", self.on_drop)
        widget.dnd_bind("<<DragEnter>>", self.on_drag_enter)
        widget.dnd_bind("<<DragLeave>>", self.on_drag_leave)

    def on_drag_enter(self, event):
        if not self.convertendo:
            self.tree.configure(background=COLORS["drop_hover"])

    def on_drag_leave(self, event):
        self.tree.configure(background="#ffffff")

    @requires_idle
    def on_drop(self, event):
        self.tree.configure(background="#ffffff")
        files = self.root.tk.splitlist(event.data)
        self._add_files([f.strip("{}") for f in files])

    def _add_files(self, paths):
        """Helper para adicionar arquivos validando extensões e duplicatas"""
        novos = []
        for path_str in paths:
            path = Path(path_str)
            
            if path.is_file() and path.suffix.lower() in SUPPORTED_EXTENSIONS:
                if path_str not in self.arquivos:
                    novos.append(path_str)
            elif path.is_dir():
                for img in list(path.iterdir())[:100]:  # Limite de 100
                    if img.is_file() and img.suffix.lower() in SUPPORTED_EXTENSIONS:
                        img_str = str(img)
                        if img_str not in self.arquivos:
                            novos.append(img_str)
        
        if novos:
            self.arquivos.extend(novos)
            self.atualizar_lista()

    def atualizar_estado(self):
        n = len(self.arquivos)
        pode_converter = n > 0 and not self.convertendo

        # Botão converter
        self.btn_converter.config(
            state=tk.NORMAL if pode_converter else tk.DISABLED,
            bg=COLORS["primary"] if pode_converter else COLORS["secondary"],
            fg="#ffffff" if pode_converter else COLORS["text_muted"],
            text=f"✨ Converter ({n})" if n > 0 else "✨ Converter (0)"
        )

        # Botões de ação
        self.btn_limpar.config(state=tk.NORMAL if pode_converter else tk.DISABLED)

        # Status
        if not self.convertendo:
            if n == 0:
                self.status_label.config(text="Nenhum arquivo • Ctrl+O para adicionar")
            else:
                self.status_label.config(text=f"Pronto • {n} arquivo{'s' if n > 1 else ''} • Ctrl+Enter para converter")

        # Empty state
        if n == 0:
            self.empty_label.place(relx=0.5, rely=0.5, anchor=tk.CENTER)
        else:
            self.empty_label.place_forget()

        # Inputs
        estado = tk.DISABLED if self.convertendo else tk.NORMAL
        for widget in [self.btn_adicionar, self.btn_pasta, self.radio_webp, self.radio_png, self.check_recorte, self.check_resize]:
            widget.config(state=estado)
        self.preset_combo.config(state="readonly" if not self.convertendo else tk.DISABLED)
        self.toggle_resize()

    def toggle_resize(self):
        if self.redimensionar.get():
            self.largura_entry.config(state=tk.NORMAL, bg="#ffffff")
        else:
            self.largura_entry.config(state=tk.DISABLED, bg=COLORS["secondary"])

    def verificar_dependencias(self):
        try:
            subprocess.run(["convert", "-version"], capture_output=True, check=True)
        except:
            resposta = messagebox.askyesno(
                "ImageMagick não encontrado",
                "O ImageMagick é necessário para converter imagens.\n\nDeseja instalar agora?"
            )
            if resposta:
                subprocess.run(["x-terminal-emulator", "-e", "sudo apt install imagemagick"])

    def criar_pasta_sessao(self):
        if not self.pasta_saida.get():
            pasta_origem = Path(self.arquivos[0]).parent
            timestamp = datetime.now().strftime("%Y-%m-%d_%H-%M-%S")

            try:
                result = subprocess.run([
                    "zenity", "--entry",
                    "--title=Nome da pasta",
                    "--text=Nome para a pasta de saída:",
                    "--entry-text=BrJoy_" + timestamp
                ], capture_output=True, text=True)

                if result.returncode == 0 and result.stdout.strip():
                    nome_pasta = result.stdout.strip()
                else:
                    nome_pasta = "BrJoy_" + timestamp
            except:
                nome_pasta = "BrJoy_" + timestamp

            pasta_final = pasta_origem / nome_pasta
            pasta_final.mkdir(parents=True, exist_ok=True)
            self.pasta_saida.set(str(pasta_final))
            return pasta_final
        else:
            return Path(self.pasta_saida.get())

