    def escolher_pasta(self):
        pasta = filedialog.askdirectory(title="Escolher pasta de saída")
        if pasta:
            self.pasta_saida.set(pasta)

    @requires_idle
    def limpar_arquivos(self):
        self.arquivos = []
        self.tree.delete(*self.tree.get_children())
        self.progress_bar["value"] = 0
        self.atualizar_estado()

    @requires_idle
    def limpar_lista(self):
        self.limpar_arquivos()

    @requires_idle
    def selecionar_arquivos(self):
        try:
            result = subprocess.run([
                "zenity", "--file-selection", "--multiple",
                "--title=Selecione imagens para converter",
                "--file-filter=Imagens | " + " ".join(f"*{ext}" for ext in SUPPORTED_EXTENSIONS),
                "--file-filter=Todos os arquivos | *"
            ], capture_output=True, text=True)

            if result.returncode == 0 and result.stdout.strip():
                self._add_files(result.stdout.strip().split("|"))
        except FileNotFoundError:
            arquivos = filedialog.askopenfilenames(
                title="Selecione imagens para converter",
                filetypes=[("Imagens", " ".join(f"*{ext}" for ext in SUPPORTED_EXTENSIONS)), ("Todos", "*.*")]
            )
            if arquivos:
                self._add_files(arquivos)

    def atualizar_lista(self):
        self.tree.delete(*self.tree.get_children())
        for idx, arq in enumerate(self.arquivos):
            if isinstance(arq, str):
                # Compatibilidade com listas antigas de strings.
                entry = self._new_file_entry(arq)
                self.arquivos[idx] = entry
                arq = entry
            nome = arq.get("rel_path", Path(arq["path"]).name)
            size = self._format_size(arq["size"])
            self.tree.insert("", tk.END, values=(nome, size, arq["status"]))
        self.atualizar_estado()

    def converter(self):
        if not self.arquivos or self.convertendo:
            return

        arquivos_snapshot = [dict(arq) for arq in self.arquivos if isinstance(arq, dict)]
        if not arquivos_snapshot:
            return

        config = self._snapshot_conversion_config()
        validation_error = self._validate_conversion_config(config)
        if validation_error:
            messagebox.showerror("Configuração inválida", validation_error)
            return

        pasta_final = self._get_session_folder(arquivos_snapshot, config)
        self.convertendo = True
        self.cancel_requested = False
        self.progress_bar["maximum"] = len(arquivos_snapshot)
        self.progress_bar["value"] = 0
        self.progress_label.config(text="0%")
        self.start_spinner()
        self.atualizar_estado()
        threading.Thread(
            target=self._converter_thread,
            args=(pasta_final, arquivos_snapshot, config),
            daemon=True,
        ).start()

    def _snapshot_conversion_config(self):
        """Captura configurações da UI para uso seguro em background thread."""
        largura = self.largura_max.get().strip()
        largura_value = int(largura) if largura.isdigit() else None

        altura = self.altura_max.get().strip()
        altura_value = int(altura) if altura.isdigit() else None

        batch_sizes = []
        if self.batch_sizes_var.get():
            sizes_str = self.batch_sizes_entry.get().strip()
            batch_sizes = sorted({int(s.strip()) for s in sizes_str.split(",") if s.strip().isdigit() and int(s.strip()) > 0})

        return {
            "formato": self.formato.get(),
            "redimensionar": self.redimensionar.get(),
            "largura_max": largura_value,
            "altura_max": altura_value,
            "recorte_1x1": self.recorte_1x1.get(),
            "qualidade": int(self.qualidade.get()),
            "sharpen": self.sharpen_var.get(),
            "brightness": int(self.brightness_var.get()),
            "batch_sizes_enabled": self.batch_sizes_var.get(),
            "batch_sizes": batch_sizes,
            "substituir_no_lugar": self.substituir_no_lugar.get(),
            "manter_estrutura": self.manter_estrutura.get(),
        }

    def _validate_conversion_config(self, config):
        if config["batch_sizes_enabled"] and not config["batch_sizes"]:
            return "Batch Sizes está ativo, mas não há tamanhos válidos.\n\nExemplo: 800,1200,1920"
        if config["redimensionar"] and config["largura_max"] is None and not config["batch_sizes_enabled"]:
            return "Redimensionar está ativo, mas a largura é inválida."
        if config["altura_max"] is not None and config["largura_max"] is None and not config["batch_sizes_enabled"]:
            return "Altura foi definida sem largura."
        return None

    def cancelar_conversao(self):
        """Cancela a conversão em andamento"""
        if self.convertendo:
            self.cancel_requested = True
            self.status_label.config(text="Canceling... please wait")
            self.btn_cancel.config(state=tk.DISABLED)

    def start_spinner(self):
        """Inicia animação do spinner"""
        self.spinner_running = True
        self.spinner_idx = 0
        self._animate_spinner()

    def stop_spinner(self):
        """Para animação do spinner"""
        self.spinner_running = False
        self.spinner_label.config(text="")

    def _animate_spinner(self):
        """Anima o spinner"""
        if self.spinner_running:
            self.spinner_label.config(text=self.spinner_frames[self.spinner_idx])
            self.spinner_idx = (self.spinner_idx + 1) % len(self.spinner_frames)
            self.root.after(80, self._animate_spinner)

    def _build_convert_cmd(self, input_path, config, width=None):
        """Constrói comando ImageMagick baseado nas configurações"""
        cmd = ["convert", str(input_path)]

        # Filtros avançados
        if config["sharpen"]:
            cmd.extend(["-sharpen", "0x1"])
        
        brightness = config["brightness"]
        if brightness != 100:
            cmd.extend(["-modulate", f"{brightness},100,100"])

        force_width = width is not None
        if force_width or (config["redimensionar"] and config["largura_max"]):
            largura = width if force_width else config["largura_max"]
            if config["altura_max"] and not force_width:
                h = config["altura_max"]
                cmd.extend(["-resize", f"{largura}x{h}^", "-gravity", "center", "-extent", f"{largura}x{h}"])
            elif config["recorte_1x1"]:
                cmd.extend(["-resize", f"{largura}x{largura}^", "-gravity", "center", "-extent", f"{largura}x{largura}"])
            else:
                cmd.extend(["-resize", f"{largura}x>"])
        elif config["recorte_1x1"]:
            cmd.extend(["-gravity", "center", "-extent", "1:1"])

        cmd.extend(["-quality", str(config["qualidade"])])

        return cmd

    def _resolve_output_folder(self, arquivo_info, pasta_final, config):
        arquivo_path = Path(arquivo_info["path"])

        if config["substituir_no_lugar"]:
            return arquivo_path.parent

        if config["manter_estrutura"]:
            rel_path = Path(arquivo_info.get("rel_path", arquivo_path.name))
            rel_parent = rel_path.parent
            if str(rel_parent) != ".":
                destino = pasta_final / rel_parent
                destino.mkdir(parents=True, exist_ok=True)
                return destino

        return pasta_final

    def _reserve_output_path(self, output_path, reserved_paths, reserve_lock):
        with reserve_lock:
            candidate = output_path
            suffix = 1
            while str(candidate) in reserved_paths or candidate.exists():
                candidate = output_path.with_name(f"{output_path.stem}_{suffix}{output_path.suffix}")
                suffix += 1
            reserved_paths.add(str(candidate))
            return candidate

    def _update_conversion_progress_ui(self, idx, status, completed, total, size_after):
        if 0 <= idx < len(self.arquivos) and isinstance(self.arquivos[idx], dict):
            self.arquivos[idx]["status"] = status
            self.arquivos[idx]["size_after"] = size_after
            nome = self.arquivos[idx].get("rel_path", Path(self.arquivos[idx]["path"]).name)
            size = self._format_size(self.arquivos[idx]["size"])
            items = self.tree.get_children()
            if idx < len(items):
                self.tree.item(items[idx], values=(nome, size, status))

        self.progress_bar["value"] = completed
        percent = int((completed / total) * 100) if total else 0
        self.progress_label.config(text=f"{percent}%")
        self.status_label.config(text=f"Converting {completed}/{total} ({MAX_WORKERS} threads)...")

    def _finish_conversion_ui(self, pasta_final, sucesso, erro, skipped, total, completed, canceled):
        self.stop_spinner()
        if canceled:
            skipped_total = skipped + max(total - completed, 0)
            self.status_label.config(text=f"Canceled: {sucesso} OK, {erro} errors, {skipped_total} skipped")
            messagebox.showwarning("Canceled", f"Conversion canceled\n\n✓ {sucesso} converted\n✗ {erro} failed\n⏸ {skipped_total} skipped")
        else:
            self.status_label.config(text=f"Completed: {sucesso} OK, {erro} errors")
            messagebox.showinfo("Completed", f"✓ {sucesso} converted\n✗ {erro} failed\n\nFolder: {pasta_final}")
            self._open_path(pasta_final)

        self.convertendo = False
        self.cancel_requested = False
        self.progress_bar["value"] = 0
        self.progress_label.config(text="0%")
        self.atualizar_estado()

    def _converter_thread(self, pasta_final, arquivos_snapshot, config):
        """Conversão paralela usando ThreadPoolExecutor"""
        formato = config["formato"]
        total = len(arquivos_snapshot)
        sucesso = erro = 0
        skipped = 0
        completed = 0
        start_time = datetime.now()
        conversion_details = []  # Lista para relatório detalhado
        reserved_paths = set()
        reserve_lock = threading.Lock()

        # Função para converter uma única imagem
        def convert_single(idx, arquivo):
            # Checar se foi cancelado
            if self.cancel_requested:
                file_label = arquivo.get("rel_path", Path(arquivo["path"]).name)
                return (idx, file_label, "⏸", None, 0, 0)
            
            arquivo_path = Path(arquivo["path"])
            file_label = arquivo.get("rel_path", arquivo_path.name)
            size_before = arquivo.get("size", arquivo_path.stat().st_size)
            
            # Decidir pasta de saída
            pasta_saida = self._resolve_output_folder(arquivo, pasta_final, config)
            
            try:
                # Batch multiple sizes
                if config["batch_sizes_enabled"]:
                    sizes = config["batch_sizes"]
                    if not sizes:
                        return (idx, file_label, "✗", "Batch sizes invalid", 0, 0)
                    
                    total_size_after = 0
                    for size in sizes:
                        if self.cancel_requested:
                            return (idx, file_label, "⏸", None, size_before, 0)
                        base_saida = pasta_saida / f"{arquivo_path.stem}_{size}w.{formato}"
                        saida = self._reserve_output_path(base_saida, reserved_paths, reserve_lock)
                        cmd = self._build_convert_cmd(arquivo_path, config, width=size)
                        cmd.append(str(saida))
                        subprocess.run(cmd, check=True, capture_output=True, text=True)
                        total_size_after += saida.stat().st_size
                    
                    return (idx, file_label, "✓", None, size_before, total_size_after)
                else:
                    # Single conversion
                    if self.cancel_requested:
                        return (idx, file_label, "⏸", None, size_before, 0)
                    base_saida = pasta_saida / f"{arquivo_path.stem}.{formato}"
                    saida = self._reserve_output_path(base_saida, reserved_paths, reserve_lock)
                    cmd = self._build_convert_cmd(arquivo_path, config)
                    cmd.append(str(saida))
                    subprocess.run(cmd, check=True, capture_output=True, text=True)
                    size_after = saida.stat().st_size
                    return (idx, file_label, "✓", None, size_before, size_after)
            except subprocess.CalledProcessError as e:
                error_msg = e.stderr.strip() if e.stderr else str(e)
                if "not recognized" in error_msg or "command not found" in error_msg:
                    return (idx, file_label, "✗", "ImageMagick not installed", 0, 0)
                elif "unable to open" in error_msg.lower():
                    return (idx, file_label, "✗", "Cannot read file", 0, 0)
                elif "memory" in error_msg.lower():
                    return (idx, file_label, "✗", "Out of memory", 0, 0)
                else:
                    return (idx, file_label, "✗", f"Convert failed: {error_msg[:50]}", 0, 0)
            except Exception as e:
                return (idx, file_label, "✗", f"Error: {str(e)[:50]}", 0, 0)

        # Processar em paralelo
        with ThreadPoolExecutor(max_workers=MAX_WORKERS) as executor:
            futures = {executor.submit(convert_single, idx, arq): idx for idx, arq in enumerate(arquivos_snapshot)}
            
            # Processar resultados conforme completam
            for future in as_completed(futures):
                if self.cancel_requested:
                    executor.shutdown(wait=False, cancel_futures=True)
                    break

                try:
                    idx, nome, status, error, size_before, size_after = future.result()
                except Exception as e:
                    idx = futures[future]
                    ref = arquivos_snapshot[idx]
                    nome = ref.get("rel_path", Path(ref["path"]).name)
                    status = "✗"
                    error = f"Internal worker error: {str(e)[:80]}"
                    size_before = ref.get("size", 0)
                    size_after = 0

                completed += 1
                
                # Salvar detalhes para relatório
                if status == "✓":
                    conversion_details.append({
                        "file": nome,
                        "before": size_before,
                        "after": size_after,
                        "saved": size_before - size_after,
                        "percent": ((size_before - size_after) / size_before * 100) if size_before > 0 else 0
                    })
                    sucesso += 1
                elif status == "⏸":
                    skipped += 1
                else:
                    erro += 1
                
                # Log erro para debug
                if status == "✗" and error:
                    print(f"Error converting {nome}: {error}")
                
                self.root.after(
                    0,
                    lambda idx=idx, status=status, completed=completed, total=total, size_after=size_after:
                        self._update_conversion_progress_ui(idx, status, completed, total, size_after)
                )

        end_time = datetime.now()
        duration = (end_time - start_time).total_seconds()
        
        # Salvar no histórico
        if sucesso > 0:
            self._save_history(pasta_final, sucesso, erro, total)
            self._generate_report(pasta_final, conversion_details, duration, sucesso, erro, total, formato)

        canceled = self.cancel_requested
        self.root.after(
            0,
            lambda: self._finish_conversion_ui(pasta_final, sucesso, erro, skipped, total, completed, canceled)
        )


