        def _on_config_mousewheel(event):
            if event.delta:
                config_canvas.yview_scroll(int(-event.delta / 120), "units")
            elif event.num == 4:
                config_canvas.yview_scroll(-1, "units")
            elif event.num == 5:
                config_canvas.yview_scroll(1, "units")

        def _bind_config_scroll(_event):
            config_canvas.bind_all("<MouseWheel>", _on_config_mousewheel)
            config_canvas.bind_all("<Button-4>", _on_config_mousewheel)
            config_canvas.bind_all("<Button-5>", _on_config_mousewheel)

        def _unbind_config_scroll(_event):
