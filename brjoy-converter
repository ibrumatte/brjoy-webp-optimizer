    def escanear_pasta(self):
        """RF01 - Scan recursivo de pastas"""
        pasta = filedialog.askdirectory(title="Selecione a pasta raiz para escanear")
        if not pasta:
            return

        self.pasta_origem = Path(pasta)
        self.arquivos = []
        self.status_label.config(text="Escaneando...")
        
        threading.Thread(target=self._escanear_thread, daemon=True).start()

    def _escanear_thread(self):
        """Escaneia recursivamente até 10 níveis"""
        encontrados = []
        total_size = 0
        
        def scan_dir(path, depth=0):
            if depth > 10:
                return
            
            try:
                for item in path.iterdir():
                    if item.is_dir():
                        if item.name not in IGNORED_DIRS:
                            scan_dir(item, depth + 1)
                    elif item.is_file() and item.suffix.lower() in SUPPORTED_EXTENSIONS:
                        rel_path = item.relative_to(self.pasta_origem)
                        size = item.stat().st_size
                        encontrados.append({
                            "path": str(item),
                            "rel_path": str(rel_path),
                            "size": size,
                            "size_after": 0,
                            "status": "—"
                        })
                        
                        if len(encontrados) >= 10000:  # Limite
                            return
            except PermissionError:
                pass
        
        scan_dir(self.pasta_origem)
        
        self.arquivos = encontrados
        total_size = sum(f["size"] for f in encontrados)
        
        self.root.after(0, self.atualizar_lista)
        self.root.after(0, lambda: self.status_label.config(
            text=f"Encontradas: {len(encontrados)} imagens ({self._format_size(total_size)})"
        ))

    def _format_size(self, bytes):
        """Formata bytes para KB/MB/GB"""
        for unit in ["B", "KB", "MB", "GB"]:
            if bytes < 1024:
                return f"{bytes:.1f} {unit}"
            bytes /= 1024
        return f"{bytes:.1f} TB"

    def setup_drag_drop(self, widget):
        if not DND_AVAILABLE:
            return

        widget.drop_target_register(DND_FILES)
        widget.dnd_bind("<<Drop>>", self.on_drop)
        widget.dnd_bind("<<DragEnter>>", self.on_drag_enter)
        widget.dnd_bind("<<DragLeave>>", self.on_drag_leave)

    def on_drag_enter(self, event):
        if not self.convertendo:
            self.tree.configure(background=COLORS["drop_hover"])

    def on_drag_leave(self, event):
        self.tree.configure(background="#ffffff")

    @requires_idle
    def on_drop(self, event):
        self.tree.configure(background="#ffffff")
        files = self.root.tk.splitlist(event.data)
        self._add_files([f.strip("{}") for f in files])

    def _add_files(self, paths):
        """Helper para adicionar arquivos validando extensões e duplicatas"""
        novos = []
        for path_str in paths:
            path = Path(path_str)
            
            if path.is_file() and path.suffix.lower() in SUPPORTED_EXTENSIONS:
                if path_str not in self.arquivos:
                    novos.append(path_str)
            elif path.is_dir():
                for img in list(path.iterdir())[:100]:  # Limite de 100
                    if img.is_file() and img.suffix.lower() in SUPPORTED_EXTENSIONS:
                        img_str = str(img)
                        if img_str not in self.arquivos:
                            novos.append(img_str)
        
        if novos:
            self.arquivos.extend(novos)
            self.atualizar_lista()

