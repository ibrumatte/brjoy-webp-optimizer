    def _validate_number(self, value):
        """Valida entrada numérica"""
        if value == "":
            return True
        try:
            num = int(value)
            return 1 <= num <= 10000
        except ValueError:
            return False

    def _update_quality_label(self, value):
        """Atualiza label do slider de qualidade"""
        self.quality_label.config(text=f"{int(float(value))}%")

    def _open_path(self, path):
        """Tenta abrir arquivo/pasta no gerenciador padrão do sistema."""
        target = str(path)
        try:
            if sys.platform.startswith("linux"):
                subprocess.Popen(["xdg-open", target], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            elif sys.platform == "darwin":
                subprocess.Popen(["open", target], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            elif os.name == "nt":
                subprocess.Popen(["cmd", "/c", "start", "", target], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        except Exception as e:
            print(f"Failed to open path {target}: {e}")

    def _safe_csv_cell(self, value):
        text = str(value).replace("\r", " ").replace("\n", " ")
        if text.startswith(("=", "+", "-", "@")):
            return "'" + text
        return text

    def _normalize_report_path(self, value):
        return str(value).replace("\r", " ").replace("\n", " ").replace("\\", "/").strip()

    def _build_converted_report_path(self, original_name, formato):
        normalized = self._normalize_report_path(original_name)
        try:
            converted = str(PurePosixPath(normalized).with_suffix(f".{formato}"))
        except ValueError:
            converted = f"{normalized}.{formato}"
        return normalized, converted

    def _sanitize_report_token(self, value):
        raw = str(value).strip().lower()
        cleaned = []
        for char in raw:
            if char.isalnum() or char in {"-", "_"}:
                cleaned.append(char)
            else:
                cleaned.append("-")
        token = "".join(cleaned)
        token = "-".join(part for part in token.split("-") if part)
        return token[:40] or "session"

    def _create_report_folder(self, output_folder):
        self.reports_dir.mkdir(parents=True, exist_ok=True)
        timestamp = datetime.now().strftime("%Y%m%d-%H%M%S")
        source_token = self._sanitize_report_token(Path(output_folder).name)
        folder = self.reports_dir / f"{timestamp}-{source_token}"
        suffix = 1
        while folder.exists():
            folder = self.reports_dir / f"{timestamp}-{source_token}-{suffix}"
            suffix += 1
        folder.mkdir(parents=True, exist_ok=True)
        return folder

    def _store_report_metadata(self, metadata):
        meta_path = Path(metadata["report_folder"]) / "report-meta.json"
        with open(meta_path, "w", encoding="utf-8") as f:
            json.dump(metadata, f, ensure_ascii=True, indent=2)
        return meta_path

    def _collect_report_entries(self):
        if not self.reports_dir.exists():
            return []

        entries = []
        meta_files = sorted(
            self.reports_dir.glob("*/report-meta.json"),
            key=lambda path: path.parent.stat().st_mtime,
            reverse=True,
        )
        for meta_path in meta_files:
            try:
                with open(meta_path, "r", encoding="utf-8") as f:
                    data = json.load(f)
                data["report_folder"] = str(Path(data.get("report_folder", meta_path.parent)))
                data["html_report"] = str(Path(data.get("html_report", Path(data["report_folder"]) / "conversion-report.html")))
                data["ai_report"] = str(Path(data.get("ai_report", Path(data["report_folder"]) / "AI-CODE-UPDATE.txt")))
                data["csv_report"] = str(Path(data.get("csv_report", Path(data["report_folder"]) / "conversions.csv")))
                entries.append(data)
            except Exception as e:
                print(f"Failed to load report metadata {meta_path}: {e}")
        return entries

    def refresh_reports_list(self, select_report=None):
        if not hasattr(self, "reports_tree"):
            return

        self.report_items = {}
        self.reports_tree.delete(*self.reports_tree.get_children())

        entries = self._collect_report_entries()
        for idx, entry in enumerate(entries):
            try:
                dt = datetime.fromisoformat(entry.get("generated_at", ""))
            except ValueError:
                dt = datetime.fromtimestamp(Path(entry["report_folder"]).stat().st_mtime)
            generated = dt.strftime("%d/%m/%Y %H:%M")
            source_folders = entry.get("source_folders") or []
            if source_folders:
                if len(source_folders) == 1:
                    source_folder = Path(source_folders[0]).name or source_folders[0]
                else:
                    source_folder = f"{len(source_folders)} pastas"
            else:
                source_folder = Path(entry.get("output_folder", "")).name or "sem saída"
            resumo = f"{entry.get('success', 0)}/{entry.get('total', 0)} ok"
            iid = self.reports_tree.insert("", tk.END, values=(generated, source_folder, resumo))
            self.report_items[iid] = entry

        if not entries:
            self.report_status_label.config(text=f"Nenhum relatório em {self.reports_dir}")
            self._toggle_report_buttons(False)
            self._show_report_preview("Nenhum relatório disponível ainda.")
            return

        self.report_status_label.config(text=f"{len(entries)} relatório(s) em {self.reports_dir}")
        selected = None
        if select_report:
            target = str(Path(select_report))
            for iid, entry in self.report_items.items():
                if str(Path(entry.get("html_report", ""))) == target:
                    selected = iid
                    break
        if selected is None:
            selected = self.reports_tree.get_children()[0]

        self.reports_tree.selection_set(selected)
        self.reports_tree.focus(selected)
        self._on_report_selected()

    def _show_report_preview(self, text):
        if not hasattr(self, "report_preview"):
            return
        self.report_preview.config(state=tk.NORMAL)
        self.report_preview.delete("1.0", tk.END)
        self.report_preview.insert("1.0", text)
        self.report_preview.config(state=tk.DISABLED)

    def _toggle_report_buttons(self, has_selection):
        state = tk.NORMAL if has_selection else tk.DISABLED
        if hasattr(self, "btn_open_report_html"):
            self.btn_open_report_html.config(state=state)
            self.btn_open_report_ai.config(state=state)
            self.btn_open_report_csv.config(state=state)
            self.btn_open_report_folder.config(state=state)

    def _on_report_selected(self, event=None):
        selection = self.reports_tree.selection() if hasattr(self, "reports_tree") else ()
        if not selection:
            self._toggle_report_buttons(False)
            return

        entry = self.report_items.get(selection[0])
        if not entry:
            self._toggle_report_buttons(False)
            return

        self._toggle_report_buttons(True)
        ai_path = Path(entry.get("ai_report", ""))
        if ai_path.exists():
            preview = ai_path.read_text(encoding="utf-8", errors="ignore")
            self._show_report_preview(preview[:6000])
        else:
            source_folders = entry.get("source_folders") or []
            source_text = ", ".join(source_folders) if source_folders else entry.get("output_folder", "")
            fallback = (
                f"Relatório: {entry.get('html_report', '')}\n"
                f"Pasta(s) convertida(s): {source_text}\n"
                f"Resumo: {entry.get('success', 0)}/{entry.get('total', 0)} ok, {entry.get('errors', 0)} erros\n"
            )
            self._show_report_preview(fallback)

    def _get_selected_report_entry(self):
        if not hasattr(self, "reports_tree"):
            return None
        selection = self.reports_tree.selection()
        if not selection:
            return None
        return self.report_items.get(selection[0])

    def _open_selected_report_file(self, kind):
        entry = self._get_selected_report_entry()
        if not entry:
            return

        field_map = {
            "html": "html_report",
            "ai": "ai_report",
            "csv": "csv_report",
            "folder": "report_folder",
        }
        target = entry.get(field_map[kind])
        if not target:
            return
        target_path = Path(target)
        if not target_path.exists():
            messagebox.showerror("Arquivo não encontrado", f"Não foi possível abrir:\n{target_path}")
            return
        self._open_path(target_path)

    def _on_reports_generated(self, report_metadata):
