    @requires_idle
    def limpar_arquivos(self):
        self.arquivos = []
        self.tree.delete(*self.tree.get_children())
        self.progress_bar["value"] = 0
        self.atualizar_estado()

    @requires_idle
    def selecionar_arquivos(self):
        try:
            result = subprocess.run([
                "zenity", "--file-selection", "--multiple",
                "--title=Selecione imagens para converter",
                "--file-filter=Imagens | " + " ".join(f"*{ext}" for ext in SUPPORTED_EXTENSIONS),
                "--file-filter=Todos os arquivos | *"
            ], capture_output=True, text=True)

            if result.returncode == 0 and result.stdout.strip():
                self._add_files(result.stdout.strip().split("|"))
        except FileNotFoundError:
            arquivos = filedialog.askopenfilenames(
                title="Selecione imagens para converter",
                filetypes=[("Imagens", " ".join(f"*{ext}" for ext in SUPPORTED_EXTENSIONS)), ("Todos", "*.*")]
            )
            if arquivos:
                self._add_files(arquivos)

    def atualizar_lista(self):
        self.tree.delete(*self.tree.get_children())
        for arq in self.arquivos:
            nome = Path(arq).name
            self.tree.insert("", tk.END, values=(nome, "—"))
        self.atualizar_estado()

    def converter(self):
        if not self.arquivos or self.convertendo:
            return

        pasta_final = self.criar_pasta_sessao()
        self.convertendo = True
        self.atualizar_estado()
        threading.Thread(target=self._converter_thread, args=(pasta_final,), daemon=True).start()

    def _build_convert_cmd(self, input_path):
        """Constrói comando ImageMagick baseado nas configurações"""
        cmd = ["convert", str(input_path)]

        if self.redimensionar.get():
            try:
                largura = int(self.largura_max.get())
                altura = self.altura_max.get()
                
                if altura:  # Preset com altura definida
                    h = int(altura)
                    cmd.extend(["-resize", f"{largura}x{h}^", "-gravity", "center", "-extent", f"{largura}x{h}"])
                elif self.recorte_1x1.get():  # Crop quadrado
                    cmd.extend(["-resize", f"{largura}x{largura}^", "-gravity", "center", "-extent", f"{largura}x{largura}"])
                else:  # Resize simples
                    cmd.extend(["-resize", f"{largura}x>", "-quality", "90"])
            except ValueError:
                pass
        elif self.recorte_1x1.get():  # Crop sem resize
            cmd.extend(["-gravity", "center", "-extent", "1:1"])

        return cmd

    def _converter_thread(self, pasta_final):
        formato = self.formato.get()
        total = len(self.arquivos)
        sucesso = erro = 0

        self.progress_bar["maximum"] = total
        self.progress_bar["value"] = 0

        for idx, arquivo in enumerate(self.arquivos):
            arquivo_path = Path(arquivo)
            saida = pasta_final / f"{arquivo_path.stem}.{formato}"

            try:
                item_id = self.tree.get_children()[idx]
                self.tree.item(item_id, values=(arquivo_path.name, "⏳"))
                self.status_label.config(text=f"Convertendo {idx+1} de {total}...")

                cmd = self._build_convert_cmd(arquivo_path)
                cmd.append(str(saida))
                subprocess.run(cmd, check=True, capture_output=True)

                self.tree.item(item_id, values=(arquivo_path.name, "✓"))
                sucesso += 1
            except Exception:
                self.tree.item(item_id, values=(arquivo_path.name, "✗"))
                erro += 1

            self.progress_bar["value"] = idx + 1

        self.status_label.config(text=f"Concluído: {sucesso} OK, {erro} erros")
        messagebox.showinfo("Concluído", f"✓ {sucesso} convertidos\n✗ {erro} falhas\n\nPasta: {pasta_final}")

        self.convertendo = False
        self.atualizar_estado()
        subprocess.run(["xdg-open", str(pasta_final)])


